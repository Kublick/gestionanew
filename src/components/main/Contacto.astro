---
import { Image } from 'astro:assets'
import Logo from '../../assets/blacklogo.svg'
import FB from '../../assets/facebook.png'
import IG from '../../assets/insta.png'
import YT from '../../assets/yt.png'
import { whatsappLink } from '../../utils/contants'
---

<style>
	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(30px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@keyframes pulse-wa {
		0%, 100% { box-shadow: 0 0 0 0 rgba(179, 167, 217, 0.5); }
		50% { box-shadow: 0 0 0 16px rgba(179, 167, 217, 0); }
	}

	.animate-in { animation: fadeInUp 0.6s ease-out both; }
	.delay-100 { animation-delay: 0.1s; }
	.delay-200 { animation-delay: 0.2s; }
	.delay-300 { animation-delay: 0.3s; }

	.wa-pulse {
		animation: pulse-wa 2s ease-in-out infinite;
	}
</style>

<section id="contacto" class="pb-8">
	<div class="z-10 mx-10 my-10 -translate-y-32 bg-white p-8 drop-shadow-xl md:mx-56 md:p-16">
		<div class="flex flex-col gap-4">
			<div class="md:flex md:gap-8">
				<div class="flex flex-col justify-between gap-4 animate-in delay-100">
					<div>
						<h1 class="mb-7 bg-white text-center text-2xl md:mb-2 md:text-left md:text-4xl">
							CONTACTO
						</h1>
						<svg xmlns="http://www.w3.org/2000/svg" width="249" height="4" viewBox="0 0 249 4" fill="none">
							<path d="M0 2H249" stroke="#D9D9D9" stroke-width="3"></path>
						</svg>
					</div>

					<a
						href={whatsappLink}
						class="wa-pulse group mb-4 flex w-full items-center justify-center gap-3 rounded-xl p-4 text-center text-sm text-white shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl md:mb-0 md:min-w-[380px] md:text-xl"
					style="background: linear-gradient(to right, #9B8EC5, #B3A7D9)"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="transition-transform duration-300 group-hover:scale-110">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.162-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
						</svg>
						<span class="font-bold">+52 (686) 234 - 9366</span>
						<span class="rounded-full bg-white/20 px-3 py-0.5 text-xs">Escribir</span>
					</a>
				</div>

				<div
					class="flex w-full flex-col items-center justify-center gap-2 rounded-xl p-4 text-center text-sm text-white shadow-lg md:gap-4 md:text-xl animate-in delay-200"
				style="background: linear-gradient(to bottom right, #9B8EC5, #B3A7D9)"
				>
					<div class="flex gap-2">
						<svg width="23" height="23" viewBox="0 0 23 23" fill="none" xmlns="http://www.w3.org/2000/svg">
							<g id="clock">
								<path id="Vector" fill-rule="evenodd" clip-rule="evenodd" d="M11.4998 20.6998C13.9398 20.6998 16.2799 19.7305 18.0052 18.0052C19.7305 16.2799 20.6998 13.9398 20.6998 11.4998C20.6998 9.05981 19.7305 6.71976 18.0052 4.99442C16.2799 3.26909 13.9398 2.2998 11.4998 2.2998C9.05981 2.2998 6.71976 3.26909 4.99442 4.99442C3.26909 6.71976 2.2998 9.05981 2.2998 11.4998C2.2998 13.9398 3.26909 16.2799 4.99442 18.0052C6.71976 19.7305 9.05981 20.6998 11.4998 20.6998ZM12.6498 6.89981C12.6498 6.59481 12.5286 6.3023 12.313 6.08663C12.0973 5.87097 11.8048 5.7498 11.4998 5.7498C11.1948 5.7498 10.9023 5.87097 10.6866 6.08663C10.471 6.3023 10.3498 6.59481 10.3498 6.89981V11.4998C10.3499 11.8048 10.4711 12.0972 10.6868 12.3129L13.939 15.5662C14.0458 15.6731 14.1726 15.7578 14.3122 15.8156C14.4519 15.8735 14.6015 15.9032 14.7526 15.9032C14.9037 15.9032 15.0533 15.8735 15.1929 15.8156C15.3325 15.7578 15.4594 15.6731 15.5662 15.5662C15.6731 15.4594 15.7578 15.3325 15.8156 15.1929C15.8735 15.0533 15.9032 14.9037 15.9032 14.7526C15.9032 14.6015 15.8735 14.4519 15.8156 14.3122C15.7578 14.1726 15.6731 14.0458 15.5662 13.939L12.6498 11.0237V6.89981Z" fill="white"></path>
							</g>
						</svg>
						<span>Horario</span>
					</div>
					<div class="mx-4 w-full border-[1px] border-white/30"></div>
					<div class="grid grid-cols-2 items-center justify-items-start text-sm md:gap-4 md:text-xl">
						<p>Lun - Vie</p>
						<p>10:00 am a 19:00 pm</p>
						<p>Sab</p>
						<p>10:00 am a 13:00 pm</p>
					</div>
				</div>
			</div>

			<div
				class="group flex w-full flex-col items-center justify-center gap-2 rounded-xl p-4 text-center text-sm text-white shadow-lg transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl md:flex-row md:gap-4 animate-in delay-300"
			style="background: linear-gradient(to bottom right, #9B8EC5, #B3A7D9)"
			>
				<svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
					<g id="mail">
						<path id="Vector" d="M3.125 8.3335L11.3438 13.8127C11.6861 14.0411 12.0884 14.163 12.5 14.163C12.9116 14.163 13.3139 14.0411 13.6562 13.8127L21.875 8.3335M5.20833 19.7918H19.7917C20.3442 19.7918 20.8741 19.5723 21.2648 19.1816C21.6555 18.7909 21.875 18.261 21.875 17.7085V7.29183C21.875 6.73929 21.6555 6.20939 21.2648 5.81869C20.8741 5.42799 20.3442 5.2085 19.7917 5.2085H5.20833C4.6558 5.2085 4.12589 5.42799 3.73519 5.81869C3.34449 6.20939 3.125 6.73929 3.125 7.29183V17.7085C3.125 18.261 3.34449 18.7909 3.73519 19.1816C4.12589 19.5723 4.6558 19.7918 5.20833 19.7918Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
					</g>
				</svg>
				<a href="mailto:psicologaberenicebastidas@gmail.com" class="text-[11px] transition-colors duration-300 hover:text-[#E5D4A1] md:text-base">
					psicologaberenicebastidas@gmail.com
				</a>
			</div>
			<p class="pb-6 text-center text-primary md:text-xl">Mexicali, Baja California</p>
		</div>
	</div>
	<div class="mt-24">
		<Image src={Logo} alt="logo" height={Logo.height} width={Logo.width} class="tex mx-auto" />
		<svg xmlns="http://www.w3.org/2000/svg" width="249" height="4" viewBox="0 0 249 4" fill="none" class="mx-auto my-9">
			<path d="M0 2H249" stroke="#6D8C82" stroke-width="3"></path>
		</svg>
	</div>
	<div class="flex justify-center gap-12">
		<a href="https://www.facebook.com/draberenicebastida" class="transition-all duration-300 hover:-translate-y-1 hover:scale-110">
			<Image src={FB} alt="logo" height={FB.height} width={FB.width} class="tex mx-auto" />
		</a>
		<a href="www.youtube.com" class="transition-all duration-300 hover:-translate-y-1 hover:scale-110">
			<Image src={IG} alt="logo" height={IG.height} width={IG.width} class="tex mx-auto" />
		</a>
	</div>
</section>