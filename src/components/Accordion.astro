---
interface Props {
	title: string
	details: string
}

const { title, details } = Astro.props as Props
---

<div class="accordion group overflow-hidden rounded-xl border border-[#6D8C82]/20 bg-white transition-all duration-300 hover:border-[#6D8C82]/40 hover:shadow-md active:border-[#6D8C82] md:w-[500px]">
	<button
		class="accordion__button flex w-full items-center justify-between gap-3 p-4 text-left text-sm font-medium text-gray-700 transition-all duration-300 hover:text-primary md:p-5 md:text-base"
		type="button"
		id={`${title} accordion menu button`}
		aria-expanded="false"
		aria-controls={`${title} accordion menu content`}
	>
		<div class="flex items-start gap-3">
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6D8C82" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0">
				<circle cx="12" cy="12" r="10"/>
				<path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
				<path d="M12 17h.01"/>
			</svg>
			{title}
		</div>
		<svg
			class="accordion__chevron h-5 w-5 shrink-0 text-[#6D8C82] transition-all duration-300 ease-out"
			aria-hidden="true"
			xmlns="http://www.w3.org/2000/svg"
			width="24"
			height="24"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<path d="m6 9 6 6 6-6"/>
		</svg>
	</button>

	<div
		id={`${title} accordion menu content`}
		aria-labelledby={`${title} accordion menu button`}
		class="accordion__content max-h-0 overflow-hidden bg-gradient-to-b from-[#6D8C82]/5 to-transparent transition-all duration-400 ease-out"
		style="transition-duration: 400ms;"
	>
		<div class="px-4 pb-4 pt-3 md:px-5 md:pb-5 md:pt-5">
			<p class="prose max-w-full text-sm leading-relaxed text-gray-600 md:text-base">
				{details}
			</p>
		</div>
	</div>
</div>

<style>
	.accordion.active {
		border-color: #6D8C82;
		box-shadow: 0 4px 20px rgba(109, 140, 130, 0.12);
	}

	.accordion.active .accordion__button {
		color: #2D5A4A;
	}

	.accordion.active .accordion__chevron {
		transform: rotate(180deg);
		color: #2D5A4A;
	}

	.accordion__content {
		transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}
</style>

<script>
	function accordionSetup() {
		const accordionMenus = document.querySelectorAll('.accordion') as NodeListOf<HTMLElement>
		accordionMenus.forEach((accordionMenu) => {
			const accordionButton = accordionMenu.querySelector('.accordion__button') as HTMLElement
			const accordionChevron = accordionMenu.querySelector('.accordion__chevron') as HTMLElement
			const accordionContent = accordionMenu.querySelector('.accordion__content') as HTMLElement

			if (accordionButton && accordionContent && accordionChevron) {
				accordionButton.addEventListener('click', (event) => {
					const isOpen = accordionMenu.classList.contains('active')

					if (!isOpen) {
						accordionMenu.classList.add('active')
						accordionButton.setAttribute('aria-expanded', 'true')
						accordionContent.style.maxHeight = accordionContent.scrollHeight + 'px'
					} else {
						accordionMenu.classList.remove('active')
						accordionButton.setAttribute('aria-expanded', 'false')
						accordionContent.style.maxHeight = '0px'
					}
					event.preventDefault()
					return false
				})
			}
		})
	}

	accordionSetup()
	document.addEventListener('astro:after-swap', accordionSetup)
</script>