---
import { AstroFont } from 'astro-font'
import '../styles/global.css'

interface Props {
	title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Psicólogo especialista en terapia de pareja y terapia individual. Sesiones presenciales y online para mejorar comunicación, gestionar ansiedad y fortalecer tu bienestar emocional."
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<AstroFont
			config={[
				{
					name: 'Bebas Neue',
					src: [
						{
							style: 'normal',
							weight: '400',
							path: './public/fonts/BebasNeue-Regular.ttf'
						}
					],
					preload: true,
					display: 'swap',
					selector: 'h1',
					fallback: 'sans-serif'
				},
				{
					name: 'Montserrat',
					src: [
						{
							style: 'normal',
							path: './public/fonts/Montserrat-VariableFont_wght.ttf'
						}
					],
					preload: true,
					display: 'swap',
					selector: 'body',
					fallback: 'serif'
				},
				{
					name: 'Montserrat Italic',
					src: [
						{
							style: 'italic',
							path: './public/fonts/Montserrat-Italic-VariableFont_wght.ttf'
						}
					],
					preload: true,
					display: 'swap',
					selector: 'h3',
					fallback: 'serif'
				}
			]}
		/>

		<link rel="preload" href="/imagen_inicio.webp" as="image" />
		<link rel="preload" href="/imagen_sesion.webp" as="image" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="fixed bottom-6 right-6 z-50">
			<a
				href="https://wa.link/t7ddog"
				target="_blank"
				class="flex h-16 w-16 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg transition-all duration-300 hover:scale-110 hover:shadow-2xl"
				aria-label="WhatsApp"
				style="animation: pulse-wa 2s ease-in-out infinite;"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.162-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
				</svg>
			</a>
		</div>

		<style>
			@keyframes pulse-wa {
				0%, 100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.6); }
				50% { box-shadow: 0 0 0 18px rgba(37, 211, 102, 0); }
			}
		</style>

		<!-- Google Tag Manager (noscript) -->
		<noscript
			><iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-TFL5RN5"
				height="0"
				width="0"
				style="display:none;visibility:hidden"></iframe></noscript
		>
		<!-- End Google Tag Manager (noscript) -->
		<slot />
		<script is:inline>
			;(function (w, d, s, l, i) {
				w[l] = w[l] || []
				w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' })
				var f = d.getElementsByTagName(s)[0],
					j = d.createElement(s),
					dl = l != 'dataLayer' ? '&l=' + l : ''
				j.async = true
				j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl
				f.parentNode.insertBefore(j, f)
			})(window, document, 'script', 'dataLayer', 'GTM-TFL5RN5')
		</script>
	</body>
</html>
